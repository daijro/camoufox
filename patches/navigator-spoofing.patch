+/* Camoufox: Per-context navigator property manager */
+#include "NavigatorManager.h"
+
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+#include "xpcpublic.h"
+
+namespace mozilla {
+namespace dom {
+
+static uint32_t GetUserContextId(JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return 0;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  return id;
+}
+
+static bool IsDisabled(const char* aPrefix, uint32_t aId) {
+  nsAutoString dKey;
+  dKey.AppendPrintf("%s_d_%u", aPrefix, aId);
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(dKey, disabled);
+  return disabled;
+}
+
+/* static */
+bool NavigatorManager::IsPlatformFunctionEnabledForWebIDL(JSContext* aCx,
+                                                          JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  return !IsDisabled("nav_plat", id);
+}
+
+/* static */
+bool NavigatorManager::IsOscpuFunctionEnabledForWebIDL(JSContext* aCx,
+                                                       JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  return !IsDisabled("nav_oscpu", id);
+}
+
+/* static */
+bool NavigatorManager::IsHwcFunctionEnabledForWebIDL(JSContext* aCx,
+                                                     JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  return !IsDisabled("nav_hwc", id);
+}
+
+/* static */
+bool NavigatorManager::IsUaFunctionEnabledForWebIDL(JSContext* aCx,
+                                                    JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  return !IsDisabled("nav_ua", id);
+}
+
+}  // namespace dom
+}  // namespace mozilla
diff --git a/dom/base/NavigatorManager.h b/dom/base/NavigatorManager.h
new file mode 100644
index 0000000000..918d94be04
--- /dev/null
+++ b/dom/base/NavigatorManager.h
@@ -0,0 +1,97 @@
+/* Camoufox: Per-context navigator property manager */
+#ifndef mozilla_dom_NavigatorManager_h
+#define mozilla_dom_NavigatorManager_h
+
+#include "nsString.h"
+#include "nsTHashMap.h"
+#include "nsHashKeys.h"
+#include "RoverfoxStorageManager.h"
+
+namespace mozilla {
+namespace dom {
+
+class NavigatorManager {
+ public:
+  // Platform (e.g. "Win32", "MacIntel", "Linux x86_64")
+  static void SetPlatform(uint32_t aId, const nsAString& aValue) {
+    nsAutoString key;
+    key.AppendPrintf("nav_plat_%u", aId);
+    RoverfoxStorageManager::PutString(key, aValue);
+    nsAutoString dKey;
+    dKey.AppendPrintf("nav_plat_d_%u", aId);
+    RoverfoxStorageManager::PutBool(dKey, true);
+  }
+
+  static bool GetPlatform(uint32_t aId, nsAString& aOut) {
+    nsAutoString key;
+    key.AppendPrintf("nav_plat_%u", aId);
+    return RoverfoxStorageManager::GetString(key, aOut);
+  }
+
+  static bool IsPlatformFunctionEnabledForWebIDL(JSContext* aCx,
+                                                 JSObject* aObj);
+
+  // Oscpu (e.g. "Windows NT 10.0; Win64; x64")
+  static void SetOscpu(uint32_t aId, const nsAString& aValue) {
+    nsAutoString key;
+    key.AppendPrintf("nav_oscpu_%u", aId);
+    RoverfoxStorageManager::PutString(key, aValue);
+    nsAutoString dKey;
+    dKey.AppendPrintf("nav_oscpu_d_%u", aId);
+    RoverfoxStorageManager::PutBool(dKey, true);
+  }
+
+  static bool GetOscpu(uint32_t aId, nsAString& aOut) {
+    nsAutoString key;
+    key.AppendPrintf("nav_oscpu_%u", aId);
+    return RoverfoxStorageManager::GetString(key, aOut);
+  }
+
+  static bool IsOscpuFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+
+  // HardwareConcurrency (CPU core count)
+  static void SetHardwareConcurrency(uint32_t aId, uint32_t aValue) {
+    nsAutoString key;
+    key.AppendPrintf("nav_hwc_%u", aId);
+    RoverfoxStorageManager::PutUint(key, aValue);
+    nsAutoString dKey;
+    dKey.AppendPrintf("nav_hwc_d_%u", aId);
+    RoverfoxStorageManager::PutBool(dKey, true);
+  }
+
+  static uint32_t GetHardwareConcurrency(uint32_t aId) {
+    nsAutoString key;
+    key.AppendPrintf("nav_hwc_%u", aId);
+    uint32_t value = 0;
+    if (RoverfoxStorageManager::GetUint(key, value)) {
+      return value;
+    }
+    return 0;
+  }
+
+  static bool IsHwcFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+
+  // UserAgent (e.g. "Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:146.0)...")
+  static void SetUserAgent(uint32_t aId, const nsAString& aValue) {
+    nsAutoString key;
+    key.AppendPrintf("nav_ua_%u", aId);
+    RoverfoxStorageManager::PutString(key, aValue);
+    nsAutoString dKey;
+    dKey.AppendPrintf("nav_ua_d_%u", aId);
+    RoverfoxStorageManager::PutBool(dKey, true);
+  }
+
+  static bool GetUserAgent(uint32_t aId, nsAString& aOut) {
+    nsAutoString key;
+    key.AppendPrintf("nav_ua_%u", aId);
+    return RoverfoxStorageManager::GetString(key, aOut);
+  }
+
+  static bool IsUaFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+
+};
+
+}  // namespace dom
+}  // namespace mozilla
+
+#endif  // mozilla_dom_NavigatorManager_h
