+void nsGlobalWindowInner::SetNavigatorPlatform(const nsAString& platform,
+                                               ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  NavigatorManager::SetPlatform(userContextId, platform);
+  if (userContextId != 0) {
+    NavigatorManager::SetPlatform(0, platform);
+  }
+  // Self-destruct: set to undefined first to bust IC/shape caches on ARM64.
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setNavigatorPlatform", undef);
+      JS_DeleteProperty(cx, global, "setNavigatorPlatform");
+    }
+  }
+}
