--- a/dom/ipc/ContentParent.cpp
+++ b/dom/ipc/ContentParent.cpp
@@ -1231,6 +1231,26 @@ mozilla::ipc::IPCResult ContentParent::RecvCreateGMPService() {
   return IPC_OK();
 }
 
+mozilla::ipc::IPCResult ContentParent::RecvRoverfoxStoragePut(
+    const nsCString& aPrefName, const nsCString& aValue) {
+  // Only allow roverfox-namespaced prefs for security
+  if (!StringBeginsWith(aPrefName, "roverfox.s."_ns)) {
+    return IPC_OK();
+  }
+  Preferences::SetCString(aPrefName.get(), aValue);
+  return IPC_OK();
+}
+
+mozilla::ipc::IPCResult ContentParent::RecvRoverfoxStorageGet(
+    const nsCString& aPrefName, nsCString* aOutValue) {
+  if (!StringBeginsWith(aPrefName, "roverfox.s."_ns)) {
+    *aOutValue = ""_ns;
+    return IPC_OK();
+  }
+  Preferences::GetCString(aPrefName.get(), *aOutValue);
+  return IPC_OK();
+}
