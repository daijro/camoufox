+mozilla::ipc::IPCResult ContentParent::RecvRoverfoxStoragePut(
+    const nsCString& aPrefName, const nsCString& aValue) {
+  // Only allow roverfox-namespaced prefs for security
+  if (!StringBeginsWith(aPrefName, "roverfox.s."_ns)) {
+    return IPC_OK();
+  }
+  Preferences::SetCString(aPrefName.get(), aValue);
+  return IPC_OK();
+}
